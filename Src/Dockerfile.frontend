FROM python:3.12-slim

WORKDIR /app

# 1. Copy ไฟล์ requirements 
COPY requirements-frontend.txt .

# 2. ติดตั้ง Packages ของฝั่ง Python
RUN pip install --no-cache-dir -r requirements-frontend.txt

# 3. Copy ทุกอย่างในโฟลเดอร์ Src (ที่อยู่ใน Terminal ตอนนี้) เข้าไปไว้ใน /app
COPY . /app

# 4. ตั้งค่า PYTHONPATH ให้มอง /app เป็นรากหลัก (เพื่อให้ import database ได้)
ENV PYTHONPATH=/app

# 5. คำสั่งรัน FastAPI
CMD ["sh", "-c", "uvicorn frontend.api.main:app --host 0.0.0.0 --port ${PORT:-8000}"]