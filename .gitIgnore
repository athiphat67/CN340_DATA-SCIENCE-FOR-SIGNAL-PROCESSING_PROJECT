# ─────────────────────────────────────────────────────────────────────────
# Python Virtual Environments
# ─────────────────────────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
pip-log.txt
pip-delete-this-directory.txt

# ─────────────────────────────────────────────────────────────────────────
# Python Cache & Bytecode
# ─────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ─────────────────────────────────────────────────────────────────────────
# IDE & Editor
# ─────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
**/.DS_Store

# ─────────────────────────────────────────────────────────────────────────
# Jupyter & Notebooks
# ─────────────────────────────────────────────────────────────────────────
.ipynb_checkpoints
*.ipynb

# ─────────────────────────────────────────────────────────────────────────
# Project Data & Outputs
# ─────────────────────────────────────────────────────────────────────────
Src/agent_core/data/latest.json
Src/agent_core/data/payload_*.json
Src/Output/
Output/
*.json

# ─────────────────────────────────────────────────────────────────────────
# Environment Variables
# ─────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─────────────────────────────────────────────────────────────────────────
# Testing & Coverage
# ─────────────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
nosetests.xml
coverage.xml

# ─────────────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────────────
*.log
logs/

# ─────────────────────────────────────────────────────────────────────────
# Temp Files
# ─────────────────────────────────────────────────────────────────────────
*.tmp
*.bak
*.swp
*.swo
*~
.~*